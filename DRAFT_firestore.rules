rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ========================================================
    // 0. GLOBAL SAFETY NET
    // ========================================================
    match /{document=**} {
      allow read, write: if false;
    }

    // ========================================================
    // HELPER FUNCTIONS
    // ========================================================

    function isSignedIn() {
      return request.auth != null;
    }

    function isVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string 
          && id.size() >= 1 
          && id.size() <= 128 
          && id.matches('^[a-zA-Z0-9._!@#$%^&*()+= -]+$');
    }

    // ========================================================
    // VALIDATION BLUEPRINTS
    // ========================================================

    function isValidUserCreate(data) {
      let requiredFields = ['uid', 'email', 'username', 'firstName', 'lastName', 'createdAt', 'profileCompleted', 'onboardingComplete', 'dob', 'gender'];
      return data.keys().hasAll(requiredFields)
          && data.uid == request.auth.uid
          && data.email == request.auth.token.email
          && data.username is string && data.username.size() >= 3 && data.username.size() <= 32
          && data.firstName is string && data.firstName.size() <= 100
          && data.lastName is string && data.lastName.size() <= 100
          && data.dob is string
          && data.gender is string
          && data.createdAt is timestamp
          && data.profileCompleted is bool
          && data.onboardingComplete is bool
          && (data.get('photoURL', '') is string && data.get('photoURL', '').size() <= 1000);
    }

    function isValidUserUpdate(data) {
      return data.get('uid', '') == existing().uid
          && data.get('email', '') == existing().email
          && (data.get('username', '') is string && data.get('username', '').size() >= 3 && data.get('username', '').size() <= 32)
          && (data.get('updatedAt', '') is string || data.get('updatedAt', null) is timestamp || data.get('updatedAt', null) == null);
    }

    function isValidUsernameCreate(data, username) {
      return isValidId(username)
          && data.keys().hasAll(['uid', 'createdAt'])
          && data.uid == request.auth.uid
          && (data.createdAt is timestamp || data.createdAt is string);
    }

    function isValidSongRecommendation(data) {
      return data.get('id', '') is string
          && data.get('title', '') is string
          && (data.get('artist', '') is string || data.get('artist', null) == null);
    }

    function isValidSongReview(data, userId) {
      return data.get('userId', '') == userId
          && data.get('songId', '') is string
          && data.get('isLiked', false) is bool
          && (data.get('timestamp', null) is timestamp || data.get('timestamp', '') is string);
    }

    function isValidFeedback(data, userId) {
      return data.userId == userId
          && data.explanationRating is int && data.explanationRating >= 1 && data.explanationRating <= 5
          && data.suggestionRating is int && data.suggestionRating >= 1 && data.suggestionRating <= 5
          && data.timestamp == request.time;
    }

    // ========================================================
    // COLLECTIONS
    // ========================================================

    // Registry for unique usernames
    match /usernames/{username} {
      allow get: if isSignedIn();
      allow create: if isVerified() 
                    && isValidUsernameCreate(incoming(), username)
                    && existsAfter(/databases/$(database)/documents/users/$(request.auth.uid));
      
      allow delete: if isVerified() && existing().uid == request.auth.uid;
    }

    // User profiles
    match /users/{userId} {
      allow get: if isOwner(userId);
      
      allow create: if isVerified() 
                    && isOwner(userId) 
                    && isValidUserCreate(incoming())
                    && existsAfter(/databases/$(database)/documents/usernames/$(incoming().username));

      allow update: if isOwner(userId)
                    && incoming().uid == userId
                    && incoming().email == existing().email
                    && (incoming().username == existing().username || existsAfter(/databases/$(database)/documents/usernames/$(incoming().username)))
                    && (
                      // Profile Update Action
                      incoming().diff(existing()).affectedKeys().hasOnly(['username', 'firstName', 'lastName', 'dob', 'gender', 'bio', 'spotifyUrl', 'instagramUrl', 'photoURL', 'onboardingComplete', 'profileCompleted', 'updatedAt'])
                    );

      allow delete: if isOwner(userId);

      // Sub-collections
      match /likes/{songId} {
        allow list, get: if isOwner(userId);
        allow create: if isVerified() && isOwner(userId) && isValidId(songId) && isValidSongRecommendation(incoming());
        allow update: if isVerified() && isOwner(userId) && isValidId(songId) && isValidSongRecommendation(incoming());
        allow delete: if isVerified() && isOwner(userId);
      }

      match /reviews/{songId} {
        allow list, get: if isOwner(userId);
        allow create, update: if isVerified() && isOwner(userId) && isValidId(songId) && isValidSongReview(incoming(), userId);
        allow delete: if isVerified() && isOwner(userId);
      }

      match /feedback/{feedbackId} {
        allow list, get: if isOwner(userId);
        allow create: if isVerified() && isOwner(userId) && isValidId(feedbackId) && isValidFeedback(incoming(), userId);
      }

      match /curations/{curationId} {
        allow list, get: if isOwner(userId);
        allow create: if isVerified() && isOwner(userId) && isValidId(curationId) 
                      && incoming().userId == userId
                      && incoming().timestamp == request.time;
        allow delete: if isVerified() && isOwner(userId);
      }
    }

    // App reviews (Public)
    match /reviews/{reviewId} {
      allow list: if isSignedIn();
      allow get: if isSignedIn();
      allow create: if isVerified()
                    && incoming().userId == request.auth.uid
                    && incoming().rating is int && incoming().rating >= 1 && incoming().rating <= 5
                    && incoming().timestamp == request.time;
      allow update: if isVerified() 
                    && existing().userId == request.auth.uid
                    && incoming().userId == request.auth.uid
                    && incoming().rating is int && incoming().rating >= 1 && incoming().rating <= 5
                    && incoming().timestamp == request.time;
      allow delete: if isVerified() && existing().userId == request.auth.uid;
    }
  }
}
